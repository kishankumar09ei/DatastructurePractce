    "##1\n",
    "### User will input (3 ages).\n",
    "### Find the oldest one.\n",
    "\n",
    "def max_of_3(a,b,c):\n",
    "    max_num=a\n",
    "    if max_num < b:\n",
    "        max_age = b\n",
    "    if max_age<c:\n",
    "        max_age=c\n",
    "    return max_age\n",
    "\n",
    "max_of_3(1,3,5) \n",
    "\n"
   ]
